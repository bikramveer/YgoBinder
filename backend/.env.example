# Copy this file to .env and fill in real values. Never commit .env to git.

# PostgreSQL connection string from Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Random 256-bit secret — used to sign and verify JWTs
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Your Vercel frontend URL — used by CORS (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# Resend API key for sending OTP emails — get one at resend.com
EMAIL_API_KEY=re_xxxxxxxxxxxx

# The "from" address for verification emails — must be a verified domain in Resend
EMAIL_FROM=YgoBinder <noreply@yourdomain.com>

# Port for local development (Railway sets this automatically in production)
PORT=3001

NODE_ENV=development
